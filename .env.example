# Database (set this in GitHub Codespaces Secrets)
# Example format: mysql://USER:PASSWORD@HOST:3306/DB_NAME
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DB_NAME"

# Auth (set this in GitHub Codespaces Secrets)
JWT_SECRET="replace-with-a-long-random-secret"
REFRESH_TOKEN_SECRET="replace-with-a-second-long-random-secret"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"
# Backward-compatible alias for ACCESS_TOKEN_EXPIRES_IN
JWT_EXPIRES_IN="15m"

# Optional
NODE_ENV="development"

# One-time bootstrap (do not commit real values)
ADMIN_USERNAME="manager"
ADMIN_PASSWORD="replace-with-a-strong-password"
ADMIN_FULL_NAME="System Manager"
